APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8080
# Optional frontend override. In local dev, Vite derives the proxy target from APP_PORT by default.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
API_IMAGE=metaldocs-api:dev
WORKER_IMAGE=metaldocs-worker:dev
WEB_IMAGE=metaldocs-web:dev

# Repository mode: memory | postgres
METALDOCS_REPOSITORY=postgres

# Auth middleware
METALDOCS_AUTH_ENABLED=true
METALDOCS_AUTHZ_CACHE_TTL_SECONDS=30
METALDOCS_AUTH_SESSION_SECRET=change_me
METALDOCS_AUTH_SESSION_COOKIE_NAME=metaldocs_session
METALDOCS_AUTH_SESSION_TTL_HOURS=12
METALDOCS_AUTH_COOKIE_SECURE=false
METALDOCS_AUTH_PASSWORD_MIN_LENGTH=8
METALDOCS_AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
METALDOCS_AUTH_LOGIN_LOCK_MINUTES=15
METALDOCS_AUTH_ORIGIN_PROTECTION_ENABLED=true
METALDOCS_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1
# Technical-test only. Official API runtime ignores legacy header auth.
METALDOCS_AUTH_LEGACY_HEADER_ENABLED=false
# Bootstrap admin is local-only. Disable it outside controlled local/runtime bootstrap flows.
METALDOCS_BOOTSTRAP_ADMIN_ENABLED=true
METALDOCS_BOOTSTRAP_ADMIN_USER_ID=admin-local
METALDOCS_BOOTSTRAP_ADMIN_USERNAME=admin
METALDOCS_BOOTSTRAP_ADMIN_EMAIL=
METALDOCS_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
METALDOCS_BOOTSTRAP_ADMIN_PASSWORD=change_me
METALDOCS_RATE_LIMIT_ENABLED=false
METALDOCS_RATE_LIMIT_WINDOW_SECONDS=60
METALDOCS_RATE_LIMIT_MAX_REQUESTS=120

# Cross-origin policy
# Production recommendation: keep same-origin behind reverse proxy when possible.
# Enable CORS only for explicit allowed origins.
METALDOCS_CORS_ENABLED=false
METALDOCS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
METALDOCS_CORS_ALLOWED_METHODS=GET,POST,PUT,OPTIONS
METALDOCS_CORS_ALLOWED_HEADERS=Content-Type,X-Trace-Id
METALDOCS_CORS_EXPOSED_HEADERS=
METALDOCS_CORS_ALLOW_CREDENTIALS=false
METALDOCS_CORS_MAX_AGE_SECONDS=300

# Used only in memory repository mode for local auth simulation.
# Format: user1:admin,user2:viewer|reviewer
METALDOCS_DEV_USER_ROLES=admin-local:admin

# PostgreSQL runtime
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=metaldocs
PGUSER=metaldocs_app
PGPASSWORD=change_me
PGSSLMODE=disable

# Compose database bootstrap
POSTGRES_HOST_PORT=5433
POSTGRES_DB=metaldocs
POSTGRES_USER=metaldocs_app
POSTGRES_PASSWORD=change_me

# Optional DSN fallback
# DATABASE_URL=postgres://metaldocs_app:change_me@127.0.0.1:5433/metaldocs?sslmode=disable

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

# Attachments storage
METALDOCS_STORAGE_PROVIDER=minio
METALDOCS_ATTACHMENTS_ROOT=non_git/attachments
METALDOCS_ATTACHMENTS_SIGNING_SECRET=change_me
METALDOCS_ATTACHMENTS_DOWNLOAD_TTL_SECONDS=300
METALDOCS_MINIO_ENDPOINT=127.0.0.1:9000
METALDOCS_MINIO_ACCESS_KEY=minioadmin
METALDOCS_MINIO_SECRET_KEY=change_me
METALDOCS_MINIO_BUCKET=metaldocs-attachments
METALDOCS_MINIO_USE_SSL=false
METALDOCS_MINIO_AUTO_CREATE_BUCKET=true
METALDOCS_CARBONE_API_URL=http://carbone:4000

# Worker
METALDOCS_WORKER_POLL_INTERVAL_SECONDS=10
METALDOCS_WORKER_BATCH_SIZE=25
METALDOCS_WORKER_REVIEW_REMINDER_DAYS=14
METALDOCS_WORKER_RUN_ONCE=false
METALDOCS_WORKER_MAX_ATTEMPTS=5
METALDOCS_WORKER_RETRY_BASE_SECONDS=10
METALDOCS_WORKER_RETRY_MAX_SECONDS=300

# E2E smoke local-only seed
METALDOCS_E2E_ADMIN_USER_ID=e2e-admin
METALDOCS_E2E_ADMIN_USERNAME=e2e.admin
METALDOCS_E2E_ADMIN_EMAIL=e2e.admin@local.test
METALDOCS_E2E_ADMIN_DISPLAY_NAME=E2E Admin
METALDOCS_E2E_ADMIN_PASSWORD=E2eAdmin123!

# Go local dev cache (recommended for restricted environments)
# GOCACHE=.gocache

# MDDM Native DOCX Export rollout percentage (0 = shadow only, 100 = all users)
METALDOCS_MDDM_NATIVE_EXPORT_ROLLOUT_PCT=0

# --- docx-editor platform (W1 scaffold) ---
# See .env.v2.example for full block.
DOCGEN_V2_SERVICE_TOKEN=
METALDOCS_DOCGEN_V2_URL=http://docgen-v2:3100
METALDOCS_FANOUT_URL=http://localhost:3001
METALDOCS_DOCGEN_V2_SERVICE_TOKEN=dev-local-service-token-32chars!!
